<UserControl xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="using:Caly.Core.Controls"
                    xmlns:vm="using:Caly.Core.ViewModels"
                    x:Class="Caly.Core.Controls.BlockListControl"
                    x:DataType="vm:PopoAnalysisViewModel">

    <Design.PreviewWith>
        <StackPanel Width="400" Height="300">
            <controls:BlockListControl/>
        </StackPanel>
    </Design.PreviewWith>

    <ListBox ItemsSource="{Binding FilteredBlocks}"
             SelectedItem="{Binding SelectedBlock}">
        <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:BlockViewModel">
                <StackPanel Margin="4,2">
                    <TextBlock Text="{Binding DisplayLabel}"
                               FontWeight="SemiBold"
                               FontSize="13"/>
                    <TextBlock Text="{Binding BboxDisplay}"
                               Opacity="0.6"
                               FontSize="11"/>
                    <TextBlock Text="{Binding DisplayContent}"
                               TextWrapping="Wrap"
                               MaxLines="2"
                               Opacity="0.8"
                               FontSize="12"/>
                </StackPanel>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>