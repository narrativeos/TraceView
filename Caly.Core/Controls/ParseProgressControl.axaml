<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="using:Caly.Core.Controls"
                    xmlns:viewModels="clr-namespace:Caly.Core.ViewModels">

	<Design.PreviewWith>
		<StackPanel Width="400" Spacing="10">
			<StackPanel Background="{DynamicResource SystemRegionBrush}">
				<controls:ParseProgressControl />
			</StackPanel>
		</StackPanel>
	</Design.PreviewWith>

	<ControlTheme x:Key="{x:Type controls:ParseProgressControl}"
                  TargetType="controls:ParseProgressControl"
                  x:DataType="viewModels:DocumentViewModel">
		<Setter Property="Template">
			<ControlTemplate>
				<!-- Non-blocking bottom progress bar -->
				<Panel IsVisible="{Binding IsMinerUParsing}">
					<Border HorizontalAlignment="Stretch"
					        VerticalAlignment="Bottom"
					        Background="#E62D2D2D"
					        BorderThickness="0,1"
					        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
					        Padding="12,8">
						<StackPanel Spacing="6"
						            Orientation="Horizontal">
							<!-- Status Icon -->
							<PathIcon Width="16"
							          Height="16"
							          Data="{StaticResource spinner_regular}"
							          Foreground="{DynamicResource SystemAccentColor}"/>

							<!-- Status Text -->
							<TextBlock Text="{Binding MinerUStatusText}"
							           FontSize="12"
							           VerticalAlignment="Center"/>

							<!-- Progress Bar -->
							<ProgressBar Width="150"
							             Height="16"
							             Minimum="0"
							             Maximum="100"
							             Value="{Binding MinerUProgress}"
							             VerticalAlignment="Center"/>

							<!-- Progress Percentage -->
							<TextBlock Text="{Binding MinerUProgress, StringFormat='{}{0}%'}"
							           FontSize="11"
							           Width="35"
							           TextAlignment="Right"
							           VerticalAlignment="Center"
							           Opacity="0.7"/>

							<!-- Cancel Button -->
							<Button Content="Cancel"
							        Command="{Binding CancelMinerUParseCommand}"
							        HorizontalAlignment="Right"
							        Padding="12,2"
							        FontSize="11"/>
						</StackPanel>
					</Border>
				</Panel>
			</ControlTemplate>
		</Setter>
	</ControlTheme>
</ResourceDictionary>