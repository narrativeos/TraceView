<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="using:Caly.Core.Controls"
                    xmlns:vm="clr-namespace:Caly.Core.ViewModels">

    <Design.PreviewWith>
        <DockPanel Width="400" Height="700">
            <DockPanel Background="{DynamicResource SystemRegionBrush}">
                <controls:SettingsControl />
            </DockPanel>
        </DockPanel>
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type controls:SettingsControl}"
                  TargetType="controls:SettingsControl"
                  x:DataType="vm:MainViewModel">
        <Setter Property="Template">
            <ControlTemplate>

                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1">

                    <ScrollViewer>
                        <StackPanel Spacing="12" Margin="16">

                            <!-- License -->
                            <controls:LicenseControl/>

                            <!-- MinerU Configuration -->
                            <Expander Header="MinerU AI Configuration" IsExpanded="True">
                                <StackPanel Spacing="8" Margin="8,8">

                                    <!-- Server URL -->
                                    <Grid ColumnDefinitions="Auto,12,*" RowDefinitions="Auto">
                                        <TextBlock Grid.Column="0"
                                                   Grid.Row="0"
                                                   VerticalAlignment="Center"
                                                   Text="Server URL"/>
                                        <TextBox Grid.Column="2"
                                                 Grid.Row="0"
                                                 Margin="0,2"
                                                 Text="{Binding Settings.MinerUBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>

                                    <!-- Backend Engine -->
                                    <Grid ColumnDefinitions="Auto,12,*" RowDefinitions="Auto">
                                        <TextBlock Grid.Column="0"
                                                   Grid.Row="0"
                                                   VerticalAlignment="Center"
                                                   Text="Backend"/>
                                        <ComboBox Grid.Column="2"
                                                  Grid.Row="0"
                                                  Margin="0,2"
                                                  SelectedValue="{Binding Settings.MinerUBackend, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBoxItem Content="hybrid-engine"/>
                                            <ComboBoxItem Content="docling"/>
                                            <ComboBoxItem Content="marker"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Enable Toggle -->
                                    <CheckBox Content="Enable MinerU AI Parsing"
                                              Margin="0,4,0,0"
                                              IsChecked="{Binding Settings.MinerUEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Expander>

                            <!-- Popo Configuration -->
                            <Expander Header="Popo Configuration" IsExpanded="True">
                                <StackPanel Spacing="8" Margin="8,8">

                                    <!-- Popo Server URL -->
                                    <Grid ColumnDefinitions="Auto,12,*" RowDefinitions="Auto">
                                        <TextBlock Grid.Column="0"
                                                   Grid.Row="0"
                                                   VerticalAlignment="Center"
                                                   Text="Server URL"/>
                                        <TextBox Grid.Column="2"
                                                 Grid.Row="0"
                                                 Margin="0,2"
                                                 Text="{Binding Settings.PopoBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>

                </Border>

            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>