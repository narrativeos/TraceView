<UserControl xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="using:Caly.Core.Controls"
                    xmlns:vm="using:Caly.Core.ViewModels"
                    x:Class="Caly.Core.Controls.TreeViewControl"
                    x:DataType="vm:PopoAnalysisViewModel">

    <TreeView ItemsSource="{Binding TreeRootChildren}">
        <TreeView.ItemTemplate>
            <TreeDataTemplate x:DataType="vm:TreeNodeViewModel"
                              ItemsSource="{Binding Children}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding DisplayTitle}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DisplayInfo}"
                               Opacity="0.5"
                               FontSize="10"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </TreeDataTemplate>
        </TreeView.ItemTemplate>
    </TreeView>
</UserControl>